      "parameters": {
        "jsCode": "const memoryResult = $input.item.json || {};\nconst parserResult = $('JavaScript Parser').item.json || {};\n\nconst message = parserResult.message || '';\nconst isFinalCommand = message.includes('ส่งให้ ai สร้างเอกสาร user requirement') || message.includes('ส่งให้ ai สร้างเอกสาร');\n\nif (memoryResult.answer && !isFinalCommand) {\n  return {\n    found: true,\n    session_id: parserResult.session_id,\n    message: parserResult.message,\n    ai_response: memoryResult.answer,\n    formatted_spec: memoryResult.answer,\n    is_command: parserResult.is_command,\n    action: parserResult.action\n  };\n} else {\n  return {\n    found: false,\n    ...parserResult\n  };\n}"
      },
