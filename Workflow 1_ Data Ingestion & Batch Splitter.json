    {
      "parameters": {
        "jsCode": "const triggerData = $('Discord Trigger').item.json || {};\n\n// Stop execution if the message is from a bot\nif (triggerData.author && triggerData.author.bot) {\n  return [];\n}\n\nconst session_id = triggerData.channelId || 'test_session_001';\nconst message = triggerData.content || '';\nconst isSaveCommand = message.startsWith('/save');\nconst action = isSaveCommand ? 'save_spec' : '';\nconst formatted_spec = '';\n\n// Fetch Recent Chat History outputs\nconst historyItems = $input.all();\n\n// Reverse history to keep it in chronological order and filter out empty objects\nconst formattedHistory = historyItems\n  .filter(item => item && item.json && item.json.role)\n  .map(item => ({\n    role: item.json.role,\n    message: item.json.message\n  }))\n  .reverse();\n\nconst agentProfile = $('Fetch Agent Profile').item.json || {};\n\n// Detect custom command like /fix, /logic, /learn\nconst isCommand = message.startsWith('/fix') || message.startsWith('/logic') || message.startsWith('/learn');\n\n// ล้างคำสั่งพวก /logic, /fix, /learn ออก เหลือแค่ตัวเนื้อหาคำสอน\nconst cleanMessage = message.replace(/^\\/(logic|fix|learn)\\s*/i, ''); \n\nreturn {\n  session_id,\n  message,\n  clean_message: cleanMessage,\n  chat_history: formattedHistory,\n  agent_profile: agentProfile,\n  is_command: isCommand,\n  action,\n  formatted_spec\n};"
      },
