    {
      "parameters": {
        "functionCode": "let txt = $json.content;\n txt = txt.replace(/<@!\\d+>/g, \"\"); // remove mention\n txt = txt.replace(/:[a-z_]+:/g, \"\"); // remove emoji\n txt = txt.replace(/[`*_~]/g, \"\"); // remove markdown formatting\n txt = txt.trim().substring(0, 500);\n return { cleanText: txt };"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        80,
        200
      ],
      "id": "sanitize",
      "name": "Sanitization"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT role_name, experience_years FROM user_role WHERE user_id = $json.authorId;",
        "options": {}
      },
      "type": "n8n-nodes-base.sqlite",
      "typeVersion": 1,
      "position": [
        260,
        200
      ],
      "id": "role_lookup",
      "name": "User Role Lookup",
      "credentials": {
        "sqlite": {
          "id": "sqlite-db",
          "name": "SQLite DB"
        }
      }
    },
    {
      "parameters": {
        "functionCode": "const role = $json[0]?.role_name || \"Managing Director\";\n const exp = $json[0]?.experience_years || 5;\n const question = $json.cleanText;\n const prompt = `คุณคือ ${role} ที่มีประสบการณ์ ${exp} ปี ฉันอยากทำระบบโพสต์คอนเทนต์ขายของใน Facebook โดยใช้ AI เข้ามาช่วยเพิ่มรายได้ จะต้องทำอย่างไร? ให้ตอบในมุมมองของ ${role} และเสนอไอเดียให้ทีมงานทำต่อได้\n\nคำถามผู้ใช้: ${question}`;\n return { prompt };"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        440,
        200
      ],
      "id": "prompt_builder",
      "name": "Prompt Builder"
    },
    {
      "parameters": {
        "url": "http://localhost:8000/v1/completions",
        "method": "POST",
        "jsonParameters": true,
        "options": {
          "headers": {
            "Authorization": "Bearer {{$env.GPT_OSS_API_KEY}}",
            "Content-Type": "application/json"
          }
        },
        "bodyParametersJson": "{\n  \"model\": \"gpt-oss-120b\",\n  \"prompt\": \"{{$json.prompt}}\",\n  \"max_tokens\": 500,\n  \"temperature\": 0.3\n}"
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        620,
        200
      ],
      "id": "gpt_request",
      "name": "GPT‑OSS Request"
    },
    {
      "parameters": {
        "functionCode": "return { reply: $json.choices[0].text };"
      },
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        800,
        200
      ],
      "id": "extract_response",
      "name": "Extract Response"
    },
    {
      "parameters": {
