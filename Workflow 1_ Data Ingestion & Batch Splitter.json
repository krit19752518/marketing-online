    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH last_response AS (\n  SELECT message FROM chat_history \n  WHERE session_id = $2 AND role = 'assistant' \n  ORDER BY created_at DESC LIMIT 1\n),\nlast_question AS (\n  SELECT message FROM chat_history\n  WHERE session_id = $2 AND role = 'user'\n  ORDER BY created_at DESC LIMIT 1\n)\nINSERT INTO project_specs (session_id, formatted_spec, status) \nVALUES (\n  $2, \n  COALESCE(NULLIF($1, ''), (SELECT message FROM last_response), ''), \n  'draft'\n) \nON CONFLICT (session_id) \nDO UPDATE SET \n  formatted_spec = EXCLUDED.formatted_spec, \n  updated_at = NOW();\n\nWITH last_response AS (\n  SELECT message FROM chat_history \n  WHERE session_id = $2 AND role = 'assistant' \n  ORDER BY created_at DESC LIMIT 1\n),\nlast_question AS (\n  SELECT message FROM chat_history\n  WHERE session_id = $2 AND role = 'user'\n  ORDER BY created_at DESC LIMIT 1\n)\nINSERT INTO qa_memory (session_id, question, answer) \nVALUES (\n  $2, \n  COALESCE(NULLIF($3, ''), (SELECT message FROM last_question), 'Default Question'), \n  COALESCE(NULLIF($1, ''), (SELECT message FROM last_response), '')\n) \nON CONFLICT (session_id, question) \nDO UPDATE SET \n  answer = EXCLUDED.answer, \n  updated_at = NOW();",
        "options": {
          "queryReplacement": "={{ [ $json.formatted_spec, $json.session_id, $json.message ] }}"
        }
      },
