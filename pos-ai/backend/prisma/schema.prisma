generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  OWNER
  MANAGER
  CASHIER
  STAFF
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  SERVED
  BILLING
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  QR_MOCK
  CREDIT_CARD
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id          String          @id @default(uuid())
  name        String
  price       Float
  imageUrl    String?
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options     ProductOption[]
  orderItems  OrderItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProductOption {
  id        String   @id @default(uuid())
  name      String // e.g., "Sweetness 50%", "Extra Cheese"
  price     Float    @default(0.0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id        String   @id @default(uuid())
  number    String   @unique
  status    String   @default("VACANT") // VACANT, OCCUPIED, BILLING
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id          String        @id @default(uuid())
  tableId     String?
  table       Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  status      OrderStatus   @default(PENDING)
  totalAmount Float         @default(0.0)
  items       OrderItem[]
  transaction Transaction?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int
  notes       String?
  selectedOpts Json? // Array of { name: string, price: number }
  subtotal    Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Transaction {
  id            String        @id @default(uuid())
  orderId       String        @unique
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod
  amountPaid    Float
  discount      Float         @default(0.0)
  change        Float         @default(0.0)
  createdAt     DateTime      @default(now())
}

model Inventory {
  id          String   @id @default(uuid())
  name        String   @unique
  quantity    Float    @default(0.0)
  unit        String // e.g., "kg", "g", "pcs", "litre"
  minQuantity Float    @default(0.0) // For low stock warning
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
